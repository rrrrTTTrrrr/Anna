#To use this function use the mount command function to find the mount location of the the device /dev/something
function SetDeviceLabel {  #Change device label
#$1 - current label
#$2 - device name ( can be found using -> df -h, should be something like /dev/sdh1, only the sdh1 is needed )
#$3 - new label
	
	UnmountDeviceFromFileSystem $1  #first unmount the device
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed to unmount the device\n"
			return 1
		fi
	
	printf mtools_skip_check=1 > ~/.mtoolsrc   #disable the 64 bit check
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed to disable the 64 bit check\n"
			return 1
		fi
	
	sudo dosfslabel /dev/$2 ::$3   #set a new label to desired path
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed setting the new device label\n"
			return 1
		fi
	
	printf mtools_skip_check=0 > ~/.mtoolsrc  #enable the 64 bit check
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed to enable the 64 bit check\n"
			return 1
		fi
	
	return 0
}
alias sdl='SetDeviceLabel'



