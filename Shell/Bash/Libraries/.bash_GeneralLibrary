function GitUpdateBranch {  #Change current branch
#$@ - branch name
	
	git stash
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed stashing current changes\n"
			return 1
		fi
	
	git remote update
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed updating branch\n"
			return 1
		fi
	
	git fetch origin $1
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed fetching branch\n"
			return 1
		fi
	
	git rebase --merge FETCH_HEAD
		if [ $? -eq 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed to rebase head\n"
			return 1
		fi
	
	git stash apply
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed to apply the stash on the updated branch\n"
			return 1
		fi
	
	return 0
}
