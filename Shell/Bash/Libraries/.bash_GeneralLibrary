function CreateNewAnnaVersion {  #Start working on a new copy of anna, to prevent destroying previous work

	cd /home/$USER/Anna/AnnaVersions/
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed to move to required directory\n"
			return 1
		fi
	
	/home/$USER/Anna/Managment/Programs/VersionManagment $ACTIVE_VERSION
		if [ $? -ne 0 ]
		then
			printf "$FILE_FULL_PATH_5  --  $FUNCNAME\n"
			return 1
		fi
	
	NEW_VERSION="$(GetActiveAnnaVersion)"
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed to get new version\n"
			return 1
		fi
	
	cp -r ./$ACTIVE_VERSION/* ./$NEW_VERSION/
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed to copy the contents to new version\n"
			return 1
		fi
	
	if [ -e /home/$USER/Anna/Managment/AnnaVersion/VersionChanges.txt ]
	then

		printf "\n\n\n\n\nAnna Version ${ACTIVE_VERSION#*_} : $(date)\n" >> /home/$USER/Anna/Managment/AnnaVersion/VersionChanges.txt
			if [ $? -ne 0 ]
			then
				Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed to echo the required pattern into the version changes file\n"
				return 1
			fi
	
	else
	
		printf "This file lists the capabilities of every anna version, and why a new version was created\n\n\n\n\nAnna Version ${NEW_VERSION#*_} : $(date)\n" > /home/$USER/Anna/Managment/AnnaVersion/VersionChanges.txt
			if [ $? -ne 0 ]
			then
				Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed to create the version changes file and echo the required pattern into it\n"
				return 1
			fi
	
	fi

	#Set the values to the file system related environment variables
	SetFileSystemEnvironmentVariables
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 "Failed setting the file system related environment variables\n"
			return 1
		fi
	
	subl /home/$USER/Anna/Managment/AnnaVersion/VersionChanges.txt
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed to open the version changes file using sublime\n"
			return 1
		fi

	return 0
}
alias newannaversion='CreateNewAnnaVersion'