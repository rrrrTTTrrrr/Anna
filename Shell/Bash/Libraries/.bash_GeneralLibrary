function UnmountDeviceFromFileSystem {  #Unmount device
#$@ - device name
	
	IsDeviceConnected $@
		if [ $? -ne 1 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed because the device is not currently mounted\n"
			return 1		
		fi

	sudo umount /media/$USER/$@
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_5 $FUNCNAME "Failed unmounting device from file system\n"
			return 1
		fi
	
	return 0
}
