function CopyAnnaFromHardDiskToMediaDevice {  # Copy all the anna directory into external hard drive
# $@ - Hard disk label

	IsDeviceConnected $@
		if [ $? -ne 1 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_7 $FUNCNAME "Failed because the device is not currently mounted - $@\n"
			return 1		
		fi

	if [ -d "/media/$USER/$@/Anna/" ]
	then

		rm -rf /media/$USER/$@/Anna/*
			if [ $? -ne 0 ]
			then
				Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_7 $FUNCNAME "Failed to remove the contents of anna from media device - $@\n"
				return 1
			fi

	else

		mkdir /media/$USER/$@/Anna/
			if [ $? -ne 0 ]
			then
				Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_7 $FUNCNAME "Failed to create the required directory for anna on the media device - $@\n"
				return 1
			fi

	fi

	cp -r /home/$USER/Anna/* /media/$USER/$@/Anna/
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_7 $FUNCNAME "Failed to copy the contents of anna to media device - $@\n"
			return 1
		fi

	return 0
}
alias annatodisk='CopyAnnaFromHardDiskToMediaDevice'





