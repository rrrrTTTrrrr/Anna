function CreateNewDirectory {  # Create a new directory, it can only create the directory in the current working directory
# $@ - the new directory name

	mkdir $@
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_7 $FUNCNAME "Failed to create the directory - $@\n"
			return 1
		fi

	g $@
		if [ $? -ne 0 ]
		then
			return 1
		fi

	return 0
}
alias mkdirg='CreateNewDirectory'


function FindAllFileNamesApperancesMatchingThePattern {  # Use to find all the file names matching a specific pattern
# $@ - the pattern that needs to be found in the files name

	find . -type f -name $@
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_7 $FUNCNAME "The find command failed to find all the files with the given pattern in the name\n"
			return 1
		fi
	
	return 0
}
alias findall='FindAllFileNamesApperancesMatchingThePattern'


function DeleteAllFilesWithNamesMatchingThePattern {  # Use to delete all the file with names matching a specific pattern
# $@ - the pattern that needs to be found in the files name

	find . -type f -name $@ -delete
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_7 $FUNCNAME "The find command failed to delete all the files with the given pattern in the name\n"
			return 1
		fi
	
	return 0
}
alias deleteall='DeleteAllFilesWithNamesMatchingThePattern'


function DeleteAllNonSourceCodeFiles {  # Use to delete all the non source code files
# $@ - the pattern that needs to be found in the files name

	DeleteAllFilesWithNamesMatchingThePattern "*.gch"
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_7 $FUNCNAME "Failed to delete \"*.gch\" files\n"
			return 1
		fi
	
	DeleteAllFilesWithNamesMatchingThePattern "PreproccessedSourceCode.cpp"
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_7 $FUNCNAME "Failed to delete files with the names \"PreproccessedSourceCode.cpp\"\n"
			return 1
		fi

	DeleteAllFilesWithNamesMatchingThePattern "a.out"
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_7 $FUNCNAME "Failed to delete files with the names \"a.out\"\n"
			return 1
		fi

	return 0
}
