function SetDate {  # Set the date
# $@ - the date - pattern -> yyyy-dd--mm
	
	date --set $@
		if [ $? -ne 0 ]
		then
			printf "$FILE_FULL_PATH_1  --  $FUNCNAME  --  Failed setting date\n"
			return 1
		fi
	
	return 0
}
alias sdate='SetDate'


function SetTime {  # Set the time
# $@ = the time - pattern -> hh:mm:ss
	
	date -- set $@
		if [ $? -ne 0 ]
		then
			printf "$FILE_FULL_PATH_1  --  $FUNCNAME  --  Failed setting time\n"
			return 1
		fi
	
	return 0
}
