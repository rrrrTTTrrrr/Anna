##############################################################################    FILE SYSTEM   ################################################################################


function BackupActiveAnnaVersion {  # Use to create a backup of the active anna version

	rm -rf /home/$USER/Anna/Managment/ActiveVersionBackup/*
		if [ $? -ne 0 ]
		then
			printf "$FILE_FULL_PATH_1  --  $FUNCNAME  --  Failed to clean the active version backup\n"
			return 1
		fi

	cp -r  $ROOT_FULL_PATH /home/$USER/Anna/Managment/ActiveVersionBackup/
		if [ $? -ne 0 ]
		then
			printf "$FILE_FULL_PATH_1  --  $FUNCNAME  --  Failed to copy the active anna version\n"
			return 1
		fi

	return 0
}
alias loldaaalol='BackupActiveAnnaVersion'


function StoreLastWorkingDirectoryToFile {  # Use to create a file with the last directory used in bash

	printf "$(pwd)" > $USAGE_DATA_DIRECTORY_FULL_PATH/System.LastUsedWorkingDirectoryInBash
		if [ $? -ne 0 ]
		then
			printf "$FILE_FULL_PATH_1  --  $FUNCNAME  --  Failed to create a file with the last working directory in bash\n"
			return 1
		fi

	return 0
}
alias stttgfdvft='StoreLastWorkingDirectoryToFile'


function MoveToLastWorkingDirectoryBeforeBashSessionEnded {  # Use this to move to the last working directory used before the bash session ended

	cd $(cat $USAGE_DATA_DIRECTORY_FULL_PATH/System.LastUsedWorkingDirectoryInBash)
		if [ $? -ne 0 ]
		then
			printf "$FILE_FULL_PATH_1  --  $FUNCNAME  --  Failed reading the file with last working directory path"
 			return 1
		fi

	return 0
}
alias mlast='MoveToLastWorkingDirectoryBeforeBashSessionEnded'


function StorePinnedDirectoryToFile {  # Use to create a file with the pinned directory used in bash

	printf "$USER_PINNED_DIRECTORY" > $USAGE_DATA_DIRECTORY_FULL_PATH/System.PinnedWorkingDirectoryInBash
		if [ $? -ne 0 ]
		then
			printf "$FILE_FULL_PATH_1  --  $FUNCNAME  --  Failed to create a file with the pinned directory in bash\n"
			return 1
		fi

	return 0
}
alias oooooooooolll='StorePinnedDirectoryToFile'



################################################################################################################################################################################
#                                                        CREATE A TRAP FOR END OF SESSION TO ENABLE GRACEFULL ENDING      				                                       #
################################################################################################################################################################################



function ExitOperations {  # This function will be called when the session has ended to perform all the required operations

	BackupActiveAnnaVersion
		if [ $? -ne 0 ]
		then
			return 1
		fi

	StoreLastWorkingDirectoryToFile
		if [ $? -ne 0 ]
		then
			return 1
		fi

	StorePinnedDirectoryToFile
		if [ $? -ne 0 ]
		then
			return 1
		fi

	return 0
}
alias exito='ExitOperations'


