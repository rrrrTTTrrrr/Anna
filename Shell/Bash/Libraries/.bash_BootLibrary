###################################################################   EXTRACT CURRENT ANNA CURRENT VERSION   ###################################################################


function GetActiveAnnaVersion {  # Use to find the active version and return it

	ls /home/$USER/Anna/AnnaVersions/ | sort | tail -1
		if [ $? -ne 0 ]
		then
			printf "$FUNCNAME  --  Failed getting last version of anna\n"
			return 1
		fi

	return 0
}
alias getactiveversion='GetActiveAnnaVersion'


##########################################################################   DISPLAY FUNCTION BODY   ###########################################################################


function DisplayFunctionBody {  # Use to display the implementation of the given function name
# $@ - the name of the required function

	declare -f $@
		if [ $? -ne 0 ]
		then
			printf "$FILE_FULL_PATH_1  --  $FUNCNAME  --  Failed to display the required function body\n"
			return 1
		fi

	return 0
}
alias DisplayFunctionBody='funcbody'


