				return 1
			fi

		InstallOrUpdate_GCC9
			if [ $? -ne 0 ]
			then
				Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_13 $FUNCNAME "Failed to install or update gcc\n"
				return 1
			fi

		InstallOrUpdate_GPP9
			if [ $? -ne 0 ]
			then
				Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_13 $FUNCNAME "Failed to install or update g++\n"
				return 1
			fi

		InstallOrUpdate_GDB
			if [ $? -ne 0 ]
			then
				Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_13 $FUNCNAME "Failed to install or update gdb\n"
				return 1
			fi

		InstallOrUpdate_CLAMAV
