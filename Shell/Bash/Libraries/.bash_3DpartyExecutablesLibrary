				return 1
			fi

		InstallOrUpdate_Apache2
			if [ $? -ne 0 ]
			then
				Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_13 $FUNCNAME "Failed to update Apache2\n"
				return 1
			fi

		InstallOrUpdate_Xclip
			if [ $? -ne 0 ]
