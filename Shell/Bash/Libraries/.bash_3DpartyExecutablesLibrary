# Installing clamav via the command "apt-get install clamav" doesn't actually install the clamav daemon. It only installs the freshclam daemon. The 
# first time clamd runs, it'll create /etc/clamav/clamd.conf. Also the clamav package does install clamscan, which can be invoked manually to scan 
# specific files/directories. However, by default, nothing will be scanned automatically. clamav-daemon allows scans to be triggered remotely, but 
# even that doesn't schedule scans or provide realtime protection!


function InstallOrUpdate_CLAMAV_DAEMON {  # Install clamav daemon on the system

	sudo apt-get install clamav-daemon
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_13 $FUNCNAME "Failed to install or update clamav daemon\n"
			return 1
		fi
	
	return 0
}
