function Uninstall_CLAMAV_IfExist {  # Uninstall clamav from the system. If the clamav executable is not already registered in the system the function does nothing

	Does3DpartyExecutableExist clamscan
		if [ $? -eq 1 ]
		then

			sudo apt-get remove clamav
				if [ $? -ne 0 ]
				then
					Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_13 $FUNCNAME "Failed to uninstall clamav\n"
					return 1
				fi

			sudo apt-get remove freshclam
				if [ $? -ne 0 ]
				then
					Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_13 $FUNCNAME "Failed to uninstall freshclam\n"
					return 1
				fi

			sudo apt-get clean
				if [ $? -ne 0 ]
				then
					Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_13 $FUNCNAME "Failed to clean\n"
					return 1
				fi

			sudo apt-get autoremove
				if [ $? -ne 0 ]
				then
					Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_13 $FUNCNAME "Failed to automatic remove\n"
					return 1
				fi

		fi
	
	return 0
}
