			then
				Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_13 $FUNCNAME "Failed to create a file with the last month the 3D executables were updated in bash\n"
				return 1
			fi

	fi

