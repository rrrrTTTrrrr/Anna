function Does3DpartyExecutableExist {  # Use to check if the required 3D party executable exist or not, return 0 if does not exist and 1 if exist
# $@ - application name

	# Check the length of the string returned from invoking the apt-cache with the given string, if it 0 then apt-cache did not find anything
	if [ -x "$(command -v $@)" ]
	then

		# The 3D party executable was found, return true
		return 1

	fi

	# The 3D party executable was not found, return false
	return 0
}
