			then
				Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH_13 $FUNCNAME "Failed to update clamav\n"
				return 1
			fi

		InstallOrUpdate_CLAMAV_DAEMON
