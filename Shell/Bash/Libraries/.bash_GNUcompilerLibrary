function GNU_CompileFileDebugCPP2020 {  #Use this function to compile a program as C++ standard 2020, with debug information and compiler optimizations
#$@ - file name

	printf "\n\n\n\n\n\n\n\n\n"
	
	g++-9 -m64 -masm=intel -std=c++2a -Werror -Wpedantic -g -D TEST_MODE $@	
		if [ $? -ne 0 ]
		then
			printf "\n\n\n\n\n\n\n\n\n"
			return 1
		fi
	
	./a.out
	
	printf "\n\n\n\n\n\n\n\n\n"
	
	return 0
}
alias g20d='GNU_CompileFileDebugCPP2020'


function GNU_CompileFileReleaseCPP2020 {  #Use this function to compile a program as C++ standard 2020 and compiler optimizations
#$@ - file name
	
	printf "\n\n\n\n\n\n\n\n\n"
	
	g++-9 -m64 -masm=intel -std=c++2a -Werror -Wpedantic -O3 $@	
		if [ $? -ne 0 ]
		then
			printf "\n\n\n\n\n\n\n\n\n"
			return 1
		fi
	
	./a.out
	
	printf "\n\n\n\n\n\n\n\n\n"
	
	return 0
}
alias g20r='GNU_CompileFileReleaseCPP2020'


function GNU_CompileFileDebugIgnoreWarningsCPP2020 {  #Use this function to compile a program as C++ standard 2020, with debug information and compiler optimizations
												#but ignore compiler warnings
#$@ - file name
	
	printf "\n\n\n\n\n\n\n\n\n"
	
	g++-9 -m64 -masm=intel -std=c++2a -Werror -Wpedantic -g -D TEST_MODE $@	
		if [ $? -ne 0 ]
		then
			printf "\n\n\n\n\n\n\n\n\n"
			return 1
		fi
	
	./a.out
	
	printf "\n\n\n\n\n\n\n\n\n"
	
	return 0
}
alias g20dnw='GNU_CompileFileDebugIgnoreWarningsCPP2020'


function GNU_CreateAssemblyCodeAndDisplayTheResult {  #Use this function to compile a program as C++ standard 2020, with debug information 
												  #and compiler optimizations only until the assembly code, and display the content
#$@ - file name
	
	g++-9 -S -m64 -masm=intel -std=c++2a -Werror -Wpedantic $@	
		if [ $? -ne 0 ]
		then
			return 1
		fi

	subl $@.s
		if [ $? -ne 0 ]
		then
			return 1
		fi	
	
	return 0
}
alias createassembly='GNU_CreateAssemblyCodeAndDisplayTheResult'


function GNU_CreatePreprocessedCodeAndDisplayTheResult {  #Use this function to only preprocess the source code and display the content
#$@ - file name
	
	g++-9 -E -o PreproccessedSourceCode.cpp $@	
		if [ $? -ne 0 ]
		then
			return 1
		fi

	subl PreproccessedSourceCode.cpp
		if [ $? -ne 0 ]
		then
			return 1
		fi
		
	return 0
}
alias createprepro='GNU_CreatePreprocessedCodeAndDisplayTheResult'


