function RepositoryExist {  #Check if the given repository exist
#$@ - this is the repository name to check if exist

	grep ^ /etc/apt/sources.list /etc/apt/sources.list.d/* | grep -q $@
		if [ $? -eq 0 ]
		then
			return 1
		else
			return 0
		fi

}
alias bghfnmyhjmjkkgggggkkkscfdscdscdscdk='RepositoryExist'


function AddUbuntuToolchainRepository {  #Check if the ubuntu-toolchain-r/test repository exist and if not add it. This repository conatins GCC and G++
#This is the ppa - ubuntu-toolchain-r/test

	RepositoryExist ubuntu-toolchain-r/test
		if [ $? -eq 0 ]
		then

			sudo add-apt-repository ppa:ubuntu-toolchain-r/test
				if [ $? -ne 0 ]
				then
					Logger_WriteLogMessageFromInsideFunction $ACTIVE_SESSION_LOG_FILE_FULL_PATH $FILE_FULL_PATH_8 $FUNCNAME "Failed to add ubuntu-toolchain-r/test repository\n"
					return 1
				fi

			sudo apt-get update
				if [ $? -ne 0 ]
				then
					Logger_WriteLogMessageFromInsideFunction $ACTIVE_SESSION_LOG_FILE_FULL_PATH $FILE_FULL_PATH_8 $FUNCNAME "Failed to update repositories ppa's\n"
					return 1
				fi

		fi

	return 0
}
alias bghfnmyhjmjkkgrrrrrrrrggggkkkscfdscdscdscdk='AddUbuntuToolchainRepository'



