#################################################################################   OVERVIEW    ################################################################################


# The GNU Project debugger, allows to see the internals of another program while it executes, and what the program was doing at the moment it crashed. GDB 
# can do four main kinds of things to help catch bugs in the act :
#
# 	1. Start the program, specifying anything that might affect its behavior
# 	2. Make the program stop on specified conditions
# 	3. Examine what has happened, when the program has stopped
# 	4. Change things in the program, so you can experiment with correcting the effects of one bug and go on to learn about another
#
# The program being debugged can be written in Ada, C, C++, Objective-C, Pascal ( and many other languages ). Those programs might be executing on the same 
# machine as GDB ( native ) or on another machine ( remote ). GDB can run on most popular UNIX and Microsoft Windows variants


function AttachToRunningProcessWithGDB {  #Use to attach to current running program
#$@ - process ID

	# GDB can attach to current running program using it's process ID
	gdb --pid=$@
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $ACTIVE_SESSION_LOG_FILE_FULL_PATH $FILE_FULL_PATH_8 $FUNCNAME "Failed opening a gdb session\n"
			return 1
		fi
	
	return 0
}
alias attgdb='AttachToRunningProcessWithGDB'


