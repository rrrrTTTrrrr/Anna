\
\
return ( 0 );
}\n\n\n" > ${HeaderFileNameFirstLetterUpperCase}Test.cpp
		if [ $? -ne 0 ]
		then
			printf "$FUNCNAME  --  Failed setting the template into the test file\n"
			return 1
		fi

	fi

	CompileAndExecuteString=""

	if [ "$3" = "c" ]
	then

		CompileAndExecuteString="GNU_CompileFileDebugCPP2020 ${HeaderFileNameFirstLetterUpperCase}Test.cpp $PREVIOUS_DIRECTORY/$HeaderFileNameFirstLetterUpperCase.cpp $ROOT_DIRECTORY_FULL_PATH/Level_0/Level_1/Content/Error/Exception/Exception.cpp $ROOT_DIRECTORY_FULL_PATH/Level_0/Content/AsciiStringAndIntegers/AsciiStringAndIntegers.cpp"
			if [ $? -ne 0 ]
			then
				printf "$FUNCNAME  --  Failed to create the command line string to compile and run the test\n"
				return 1
			fi

	else

		CompileAndExecuteString="GNU_CompileFileDebugCPP2020 ${HeaderFileNameFirstLetterUpperCase}Test.cpp $ROOT_DIRECTORY_FULL_PATH/Level_0/Level_1/Content/Error/Exception/Exception.cpp $ROOT_DIRECTORY_FULL_PATH/Level_0/Content/AsciiStringAndIntegers/AsciiStringAndIntegers.cpp"
