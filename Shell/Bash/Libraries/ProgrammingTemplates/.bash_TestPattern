#$3 - the letter 'c' if the object is not a template which means it contains also a source file, in case this is not needed use any other character
#$4 - a string with all the template arguments of the object testes seperated with comma

	HeaderFileName=$1
		
	HeaderFileNameFirstLetterUpperCase="${HeaderFileName^}"

	PREVIOUS_DIRECTORY=$(pwd)

	cd /tmp/
		if [ $? -ne 0 ]
		then
			printf "$FUNCNAME  --  Failed moving to required directory\n"
			return 1
		fi

	TemplateArgumentsString=""

	if [ $# -eq 4 ]
	then

		TemplateArgumentsString="<"$4">"

	fi

	if [ "$2" = "n" ]
	then

printf "#include <iostream>\n\n\n\
\
\
