using namespace Universe;\n\n\n\
\
\
int main()\n\
{\n\n    \
\
\
try\n    \
{\n\n\n    	\
\
\
// Call the test method of the object\n    	\
${HeaderFileNameFirstLetterUpperCase}${TemplateArgumentsString}::Test();\n\n\n    \
\
\
}\n    \
catch ( const Error::Exception& exception )\n    \
{\n    	\
exception.TellMe();\n    \
}\n    \
catch ( const exception& stdException )\n    \
{\n    \
	cout << stdException.what() << endl;\n    \
}\n\n    \
\
\
return ( 0 );
}\n\n\n" > ${HeaderFileNameFirstLetterUpperCase}Test.cpp
		if [ $? -ne 0 ]
		then
