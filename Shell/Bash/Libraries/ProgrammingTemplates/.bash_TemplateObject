function CreateNewCppTemplateObjectOrientedProjectAndOpenItWithSublime {	#Create new c++ template object project ( header + cpp ) and open it with sublime
#$1 - probject name
#$2 - namespace
#$3 - the character 'd' if the user required to also create a directory for the new project

	ProjectName=$1

	ProjectNameFirstLetterUpperCase="${ProjectName^}"


	if [ "$3" = "d" ]
	then

		mkdir $ProjectNameFirstLetterUpperCase
			if [ $? -ne 0 ]
			then
				printf "$FUNCNAME  --  Failed to create the directory for the new project\n"
				return 1
			fi

		g $ProjectNameFirstLetterUpperCase
			if [ $? -ne 0 ]
			then
				return 1
			fi

	fi

	CreateCppTemplateObjectOrientedHeaderFile $1 $2
		if [ $? -ne 0 ]
		then
			printf "$FUNCNAME  --  Failed to set the pattern into the header file\n"
			return 1
		fi

	subl $ProjectNameFirstLetterUpperCase*
		if [ $? -ne 0 ]
		then
			printf "$FUNCNAME  --  Failed to open file using sublime\n"
			return 1
		fi

	return 0
}
alias newt='CreateNewCppTemplateObjectOrientedProjectAndOpenItWithSublime'


