function NoInstances {  # Use this function to copy to the clipboard the comment plus the macro 'NoInstances'

	printf "			// Disable all default generated methods - constructor, destructor, copy constructor, assignment operator, move constructor and move assignment operator\n			NoInstances_MACRO( ObjectName )" | copyout
		if [ $? -ne 0 ]
		then
			return 1
		fi
	
	return 0
}
alias noinst='NoInstances'


function DisableCopyAndMove {  # Use this function to copy to the clipboard the comment plus the macro 'DisableCopyAndMove_MACRO'

	printf "			// Disable all copy and move related methods, this include the copy constructor, move constructor, assignment operator and move assignment operator\n			DisableCopyAndMove_MACRO( ObjectName )" | copyout
		if [ $? -ne 0 ]
		then
			return 1
		fi
	
	return 0
}
alias discm='DisableCopyAndMove'


function DisableCopy {  # Use this function to copy to the clipboard the comment plus the macro 'DisableCopyConstructorAndAssignmentOperator_MACRO'

	printf "			// Disable all the abilites of the object to copy itself, this include the copy constructor and assignment operator\n			DisableCopyConstructorAndAssignmentOperator_MACRO( ObjectName )" | copyout
		if [ $? -ne 0 ]
		then
			return 1
		fi
	
	return 0
}
alias discopy='DisableCopy'


