function CLANG_CompileFileDebugCPP17 {  #Use this function to compile a program as C++ standard 17, with debug information and compiler optimizations
#$@ - file name

	printf "\n\n\n\n\n\n\n\n\n"
	
	clang -m64 -masm=intel -std=c++17 -Werror -Wpedantic -Wall -Wextra -g -D TEST_MODE $@	
		if [ $? -ne 0 ]
		then
			printf "\n\n\n\n\n\n\n\n\n"
			return 1
		fi
	
	./a.out
	
	printf "\n\n\n\n\n\n\n\n\n"
	
	return 0
}
alias cl17d='CLANG_CompileFileDebugCPP17'


function CompileFileReleaseCPP17 {  #Use this function to compile a program as C++ standard 17 and compiler optimizations
#$@ - file name
	
	printf "\n\n\n\n\n\n\n\n\n"
	
	clang -m64 -masm=intel -std=c++17 -Werror -Wpedantic -Wall -Wextra -O3 $@	
		if [ $? -ne 0 ]
		then
			printf "\n\n\n\n\n\n\n\n\n"
			return 1
		fi
	
	./a.out
	
	printf "\n\n\n\n\n\n\n\n\n"
	
	return 0
}
alias cl17r='CompileFileReleaseCPP17'


function CLANG_CompileFileDebugIgnoreWarningsCPP17 {  #Use this function to compile a program as C++ standard 17, with debug information and compiler optimizations
												#but ignore compiler warnings
#$@ - file name
	
	printf "\n\n\n\n\n\n\n\n\n"
	
	clang -m64 -masm=intel -std=c++17 -Wpedantic -Wall -Wextra -g -D TEST_MODE $@	
		if [ $? -ne 0 ]
		then
			printf "\n\n\n\n\n\n\n\n\n"
			return 1
		fi
	
	./a.out
	
	printf "\n\n\n\n\n\n\n\n\n"
	
	return 0
}
alias cl17dnw='CLANG_CompileFileDebugIgnoreWarningsCPP17'


function CLANG_CreateAssemblyCodeAndDisplayTheResult {  #Use this function to compile a program as C++ standard 17, with debug information 
												  #and compiler optimizations only until the assembly code, and display the content
#$@ - file name
	
	clang -S -m64 -masm=intel -std=c++17 -Werror -Wpedantic -Wall -Wextra $@	
		if [ $? -ne 0 ]
		then
			return 1
		fi

	EditFileUsingSublime $@.s
		if [ $? -ne 0 ]
		then
			return 1
		fi	
	
	return 0
}
alias clcreateassembly='CLANG_CreateAssemblyCodeAndDisplayTheResult'


function CLANG_CreatePreprocessedCodeAndDisplayTheResult {  #Use this function to only preprocess the source code and display the content
#$@ - file name
	
	clang -E -o PreproccessedSourceCode.cpp $@	
		if [ $? -ne 0 ]
		then
			return 1
		fi

	EditFileUsingSublime PreproccessedSourceCode.cpp
		if [ $? -ne 0 ]
		then
			return 1
		fi
		
	return 0
}
alias clcreateprepro='CLANG_CreatePreprocessedCodeAndDisplayTheResult'


