function SetCLANGrepository {  #Use to add the Clang-6 repository to apt-get

	wget -O - https://apt.llvm.org/llvm-snapshot.gpg.key | sudo apt-key add -
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH $FUNCNAME "failed to get the apt-key for clang-6 llvm\n"
			return 1
		fi

	sudo apt-add-repository "deb http://apt.llvm.org/xenial/ llvm-toolchain-xenial-6.0 main"
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH $FUNCNAME "failed to add the clang-6 repository\n"
			return 1
		fi

	sudo apt-get update
		if [ $? -ne 0 ]
		then
			Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH $FUNCNAME "failed to update apt-get repository paths\n"
			return 1
		fi
}
alias gggggggglkslkmjs="SetCLANGrepository"


function Install_CLANG6 {  #Check if clang-6 is currently installed on the system and if not install it
#This is the ppa  ->  
#					  

	Does3DpartyExecutableExist clang-6.0
		if [ $? -ne 1 ]
		then

			sudo apt-get install -y clang-6.0
				if [ $? -ne 0 ]
				then
					Logger_WriteLogMessageFromInsideFunction $LOG_FILE_FULL_PATH $FILE_FULL_PATH $FUNCNAME "failed to install gcc8\n"
					return 1
				fi

		fi

	return 0
}
alias bghfnmyhjmjkkgggggkkkk='Install_CLANG6'



